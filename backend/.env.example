# PostgreSQL connection string
# Example (local): postgresql://postgres:password@localhost:5432/gk_icecube
# Example (hosted, e.g. Supabase/Neon/Railway): copy the connection string they give you
DATABASE_URL="postgresql://postgres:password@localhost:5432/gk_icecube?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Frontend origin (for CORS)
CLIENT_ORIGIN="http://localhost:5173"

# Stripe (optional — leave blank to only offer "Cash on Delivery")
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Seed admin account (created by `npm run seed`)
SEED_ADMIN_EMAIL="admin@gkicecube.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
